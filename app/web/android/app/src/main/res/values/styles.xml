<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme — ActionBar kesinlikle devre dışı. -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowBackground">#0F1423</item>
        <item name="android:statusBarColor">#0F1423</item>
        <item name="android:navigationBarColor">#0F1423</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <!-- Artık ayrı NoActionBar stili gereksiz, AppTheme zaten NoActionBar. Geriye uyumluluk için bırakıldı. -->
    <style name="AppTheme.NoActionBar" parent="@style/AppTheme" />

    <!-- Splash screen teması — splash bittikten sonra AppTheme'e geçiş yapar. -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
        <item name="postSplashScreenTheme">@style/AppTheme</item>
    </style>
</resources>
