# Uygulama Temel
ENVIRONMENT=production
FRONTEND_URL=https://myworld-steel.vercel.app

# Veritabanı (Neon PostgreSQL)
DB_USER=your_neon_user
DB_PASSWORD=your_neon_password
DB_NAME=myworld
DB_HOST=ep-your-instance.eu-central-1.aws.neon.tech
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://your_neon_user:your_neon_password@ep-your-instance.eu-central-1.aws.neon.tech/myworld?ssl=require

# Redis (opsiyonel, henüz aktif kullanılmıyor)
REDIS_URL=redis://localhost:6379/0

# Güvenlik
SECRET_KEY=your_strong_secret_key_at_least_32_characters_here
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Yapay Zeka (Google Gemini)
GEMINI_API_KEY=your_gemini_api_key

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ADMIN_ID=your_telegram_admin_id
